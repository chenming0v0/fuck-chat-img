# fuck-chat-img 环境变量配置示例

# 监听地址
FCI_LISTEN=:8080

# SQLite 数据库路径
FCI_DB_PATH=./data/fci.db

# 前端静态资源目录(留空则使用嵌入的前端; 开发时指向 web/dist)
# 注意: 必须用"未设置"(不写该变量)来启用嵌入前端; 显式设为空字符串也会启用嵌入前端
FCI_WEB_DIR=

# JWT 密钥(务必修改! 留空则每次启动用 crypto/rand 随机生成, 会导致旧登录失效)
FCI_JWT_SECRET=

# 代理接口访问密钥(用于 /v1/* 兼容接口鉴权, 客户端通过 Authorization: Bearer <key> 传入)
# 留空时: 仅允许通过 Web UI 登录的管理员 JWT 访问代理接口(普通登录用户不可用)
# 配置后: 任何持有该 key 的客户端可访问 /v1/* (含 /v1/responses /v1/chat/completions /v1/messages)
FCI_PROXY_KEY=

# 初始管理员账户(仅首次启动且数据库无任何用户时生效, 用于自动化/容器化部署)
# 推荐生产环境通过这两个变量预置管理员, 完全绕过 /setup 公开接口(详见 AGENTS.md)
FCI_ADMIN_USER=root
# 明文传入, 服务端会 bcrypt 哈希后存储; 需满足密码强度(至少 6 位)
FCI_ADMIN_PASS=

# 缓存
FCI_CACHE_ENABLED=true
FCI_CACHE_MAX=10000

# 上游请求超时(秒); 流式请求实际使用 2 倍超时, 避免长 SSE 流被切断
FCI_REQUEST_TIMEOUT=300
