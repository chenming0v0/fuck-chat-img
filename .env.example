# fuck-chat-img 环境变量配置示例

# 监听地址
FCI_LISTEN=:8080

# SQLite 数据库路径
FCI_DB_PATH=./data/fci.db

# 前端静态资源目录(留空则使用嵌入的前端; 开发时指向 web/dist)
FCI_WEB_DIR=

# JWT 密钥(务必修改! 留空则每次启动随机生成, 会导致旧登录失效)
FCI_JWT_SECRET=

# 代理接口访问密钥(用于 /v1/* OpenAI 兼容接口鉴权, 客户端通过 Authorization: Bearer <key> 传入)
# 留空则仅允许 Web UI 登录用户访问代理接口
FCI_PROXY_KEY=

# 初始管理员账户(仅首次启动创建时生效)
FCI_ADMIN_USER=root
FCI_ADMIN_PASS=

# 缓存
FCI_CACHE_ENABLED=true
FCI_CACHE_MAX=10000

# 上游请求超时(秒)
FCI_REQUEST_TIMEOUT=300
